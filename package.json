{
  "name": "openclaw-desktop",
  "version": "1.0.0",
  "description": "OpenClaw Desktop application for prompting and task solving",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "openclaw",
    "electron",
    "desktop",
    "automation"
  ],
  "author": "OpenClaw Team",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "playwright": "^1.50.0",
    "playwright-electron": "^0.5.0"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@googleapis/docs": "^9.2.1",
    "@googleapis/drive": "^20.1.0",
    "@octokit/rest": "^22.0.1",
    "axios": "^1.13.6",
    "codemirror": "^6.0.2",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "openai": "^6.27.0",
    "puppeteer": "^24.38.0"
  },
  "build": {
    "extends": "./electron-builder.json"
  }
}
